# Copy this file to /opt/odoo-cicd-data/.env.production on your server and
# fill in real values. It lives outside the git checkout on purpose (see
# README.md) and is never committed.

DOMAIN_PROD=app.example.com
DB_USER=odoo
DB_PASSWORD=change-me
ODOO_MASTER_PASSWORD=change-me

# Kept up to date automatically by scripts/deploy.sh, one per blue/green
# slot, on every deploy. The values below are only used for the very
# first `docker compose up`, before any real deploy has run - the
# official image works fine as a bootstrap placeholder since it has no
# custom addons yet either.
IMAGE_BLUE=odoo:19.0
IMAGE_GREEN=odoo:19.0
