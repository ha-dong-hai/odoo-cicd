# Copy this file to /opt/odoo-cicd-data/.env.staging on your server and
# fill in real values. It lives outside the git checkout on purpose (see
# README.md) and is never committed.

DOMAIN_STAGING=staging.example.com
DB_USER=odoo
DB_PASSWORD=change-me
ODOO_MASTER_PASSWORD=change-me

# Kept up to date automatically by scripts/deploy.sh on every deploy. The
# value below is only used for the very first `docker compose up`, before
# any CI run has built a real image - the official image works fine as a
# bootstrap placeholder since it has no custom addons yet either.
IMAGE=odoo:19.0
